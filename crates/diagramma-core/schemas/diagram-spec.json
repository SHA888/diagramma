{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagramSpec",
  "description": "Diagram specification umbrella enum.",
  "oneOf": [
    {
      "description": "Flowchart diagram specification.",
      "type": "object",
      "required": [
        "direction",
        "edges",
        "nodes",
        "theme",
        "type"
      ],
      "properties": {
        "direction": {
          "$ref": "#/definitions/Direction"
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Edge"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Node"
          }
        },
        "theme": {
          "$ref": "#/definitions/Theme"
        },
        "type": {
          "type": "string",
          "enum": [
            "flowchart"
          ]
        }
      }
    },
    {
      "description": "Structural specification (container tree).",
      "type": "object",
      "required": [
        "containers",
        "theme",
        "type"
      ],
      "properties": {
        "containers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Container"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Edge"
          }
        },
        "theme": {
          "$ref": "#/definitions/Theme"
        },
        "type": {
          "type": "string",
          "enum": [
            "structural"
          ]
        }
      }
    },
    {
      "description": "Illustrative specification (freeform shapes, annotations).",
      "type": "object",
      "required": [
        "elements",
        "theme",
        "type"
      ],
      "properties": {
        "annotations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Element"
          }
        },
        "theme": {
          "$ref": "#/definitions/Theme"
        },
        "type": {
          "type": "string",
          "enum": [
            "illustrative"
          ]
        }
      }
    },
    {
      "description": "Interactive specification (base diagram + controls).",
      "type": "object",
      "required": [
        "base",
        "type"
      ],
      "properties": {
        "base": {
          "$ref": "#/definitions/DiagramSpec"
        },
        "controls": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Control"
          }
        },
        "type": {
          "type": "string",
          "enum": [
            "interactive"
          ]
        }
      }
    }
  ],
  "definitions": {
    "ArrowStyle": {
      "description": "Arrow styles for edges.",
      "type": "string",
      "enum": [
        "Open",
        "Closed",
        "None"
      ]
    },
    "ColorRamp": {
      "description": "Color ramps available to nodes/containers.",
      "type": "string",
      "enum": [
        "Purple",
        "Teal",
        "Coral",
        "Pink",
        "Gray",
        "Blue",
        "Green",
        "Amber",
        "Red"
      ]
    },
    "Container": {
      "description": "Container definition (recursive).",
      "type": "object",
      "required": [
        "color",
        "id",
        "label"
      ],
      "properties": {
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Element"
          }
        },
        "color": {
          "$ref": "#/definitions/ColorRamp"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "Control": {
      "description": "Interactive control definitions.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "control",
            "id",
            "label"
          ],
          "properties": {
            "control": {
              "type": "string",
              "enum": [
                "toggle"
              ]
            },
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "control",
            "id",
            "label",
            "max",
            "min"
          ],
          "properties": {
            "control": {
              "type": "string",
              "enum": [
                "slider"
              ]
            },
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "max": {
              "type": "integer",
              "format": "int32"
            },
            "min": {
              "type": "integer",
              "format": "int32"
            },
            "step": {
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "int32"
            }
          }
        }
      ]
    },
    "DiagramSpec": {
      "description": "Diagram specification umbrella enum.",
      "oneOf": [
        {
          "description": "Flowchart diagram specification.",
          "type": "object",
          "required": [
            "direction",
            "edges",
            "nodes",
            "theme",
            "type"
          ],
          "properties": {
            "direction": {
              "$ref": "#/definitions/Direction"
            },
            "edges": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Edge"
              }
            },
            "nodes": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Node"
              }
            },
            "theme": {
              "$ref": "#/definitions/Theme"
            },
            "type": {
              "type": "string",
              "enum": [
                "flowchart"
              ]
            }
          }
        },
        {
          "description": "Structural specification (container tree).",
          "type": "object",
          "required": [
            "containers",
            "theme",
            "type"
          ],
          "properties": {
            "containers": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Container"
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Edge"
              }
            },
            "theme": {
              "$ref": "#/definitions/Theme"
            },
            "type": {
              "type": "string",
              "enum": [
                "structural"
              ]
            }
          }
        },
        {
          "description": "Illustrative specification (freeform shapes, annotations).",
          "type": "object",
          "required": [
            "elements",
            "theme",
            "type"
          ],
          "properties": {
            "annotations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "elements": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Element"
              }
            },
            "theme": {
              "$ref": "#/definitions/Theme"
            },
            "type": {
              "type": "string",
              "enum": [
                "illustrative"
              ]
            }
          }
        },
        {
          "description": "Interactive specification (base diagram + controls).",
          "type": "object",
          "required": [
            "base",
            "type"
          ],
          "properties": {
            "base": {
              "$ref": "#/definitions/DiagramSpec"
            },
            "controls": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Control"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "interactive"
              ]
            }
          }
        }
      ]
    },
    "Direction": {
      "description": "Primary direction for layout engines.",
      "type": "string",
      "enum": [
        "TopDown",
        "LeftRight",
        "BottomUp",
        "RightLeft"
      ]
    },
    "Edge": {
      "description": "Edge definition.",
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "arrow": {
          "default": "Closed",
          "allOf": [
            {
              "$ref": "#/definitions/ArrowStyle"
            }
          ]
        },
        "from": {
          "type": "string"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "style": {
          "default": "Solid",
          "allOf": [
            {
              "$ref": "#/definitions/EdgeStyle"
            }
          ]
        },
        "to": {
          "type": "string"
        }
      }
    },
    "EdgeStyle": {
      "description": "Edge style variants.",
      "type": "string",
      "enum": [
        "Solid",
        "Dashed"
      ]
    },
    "Element": {
      "description": "Diagram element types.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "Node"
          ],
          "properties": {
            "Node": {
              "$ref": "#/definitions/Node"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Container"
          ],
          "properties": {
            "Container": {
              "$ref": "#/definitions/Container"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Node": {
      "description": "Node definition.",
      "type": "object",
      "required": [
        "color",
        "id",
        "label",
        "shape"
      ],
      "properties": {
        "color": {
          "$ref": "#/definitions/ColorRamp"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "shape": {
          "$ref": "#/definitions/NodeShape"
        },
        "subtitle": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "NodeShape": {
      "description": "Node shapes.",
      "type": "string",
      "enum": [
        "Rect",
        "Pill",
        "Diamond",
        "Circle"
      ]
    },
    "Theme": {
      "description": "Theme selection for specs.",
      "type": "string",
      "enum": [
        "Light",
        "Dark",
        "Auto"
      ]
    }
  }
}