{
  "name": "diagramma-monorepo",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:rust": "cargo fmt --all -- --check",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "typecheck:rust": "cargo check --all-targets --all-features",
    "lint:ts": "pnpm -r run lint --if-present",
    "typecheck:ts": "pnpm -r run typecheck --if-present",
    "precommit": "pnpm format:rust && pnpm lint:rust && pnpm typecheck:rust && pnpm format:check && pnpm lint:ts && pnpm typecheck:ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "turbo": "2.9.4",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.5"
    }
  }
}
